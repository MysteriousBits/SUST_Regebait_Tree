% --- Chapter style ---
\titleformat{\chapter}[block]
 {\Large\bfseries} % font size + bold
 {}                % no "Chapter X"
 {0pt}             % no extra spacing
 {\thechapter\quad} % (remove if you don't want numbers at all)

\titlespacing*{\chapter}
 {0pt}   % left margin
 {1em}   % space before
 {0.5em} % space after

% --- Section style (small, not bold, no rule) ---
\titleformat{\section}[block]
 {\bfseries\normalsize} % font: normal, not bold
 {} % no label/number in front
 {0pt} % no separation
 {\thesection\quad} % just print the title
 [\titleline{\rule{\linewidth}{0.2pt}}]

 % --- Subsection: Small, Bold, No Rule ---
\titleformat{\subsection}[block]
  {\bfseries\small} % Slightly smaller than section
  {}
  {0pt}
  {\thesubsection\quad}

% --- Subsubsection: Normal font, Bold, In-line ---
% This "runin" style puts the text on the same line as the title to save vertical space
\titleformat{\subsubsection}[runin]
  {\bfseries\small}
  {}
  {0pt}
  {\thesubsubsection\quad}
  [:\quad] % Adds a colon and space after the subsubsection title

