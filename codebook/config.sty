% Usage: \startcode{folder/file.cpp}
\newcommand{\code}[2]{%
  \section{#1}
  \vspace{-1em}
  \lstinputlisting{../code_library/#2}%
}

\newlength{\cwdImgWidth}
\setlength{\cwdImgWidth}{0.1\linewidth}

% \codeWithDescription{Title}{filepath}[Description][Image][Usage]
\NewDocumentCommand{\codeWithDescription}{ m m o o o }{%
  \section{#1}%
  \vspace{-0.5em}%
  %
  \IfValueT{#3}{%
    \noindent\begin{minipage}{\linewidth}%
      % --- Description + optional image ---
      \IfValueTF{#4}{%
        \if\relax\detokenize{#4}\relax
          % empty image arg → full-width description
          \noindent\footnotesize\textbf{Description:} #3\par
        \else
          % description on left, image on right
          \noindent
          \begin{minipage}[t]{\dimexpr\linewidth-\cwdImgWidth-0.5em\relax}%
            \vspace{0pt}%
            \footnotesize\textbf{Description:} #3%
          \end{minipage}%
          \hspace{0.3em}%
          \begin{minipage}[t]{\cwdImgWidth}%
            \vspace{0pt}%
            \includegraphics[width=\linewidth]{#4}%
          \end{minipage}%
          \par
        \fi
      }{%
        \noindent\footnotesize\textbf{Description:} #3\par
      }%
      \vspace{0.2em}%
      % --- Optional usage ---
      \IfValueT{#5}{%
        \noindent\footnotesize\textbf{Usage:}\\
        \indent\texttt{\footnotesize\detokenize{#5}}\par
        \vspace{0.2em}%
      }%
    \end{minipage}%
    \par\vspace{0.2em}%
  }%
  %
  \noindent{\color{lightgray}\rule{\linewidth}{0.2pt}}%
  \vspace*{-0.5em}%
  \lstinputlisting{../code_library/#2}%
  \vspace*{-1.5em}%
  \par
}